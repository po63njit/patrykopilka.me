---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'JamGuard',
    href: 'https://github.com/kyrtapaklipo/JamGuard',
    image:
      'https://opengraph.githubassets.com/1/kyrtapaklipo/JamGuard',
    imageAlt: 'JamGuard repository preview image',
    description:
      'JamGuard is an FPS anti-cheat project focused on reducing unfair play and protecting online matches.',
  },
];
---

<BaseLayout title="Projects — patrykopilka.me">
  <section class="card projects-shell">
    <h1>Projects</h1>
    <p>Click a card to open the GitHub repository.</p>

    <div class="project-deck" role="list" aria-label="Project links">
      {projects.map((project) => (
        <a
          class="project-card"
          href={project.href}
          target="_blank"
          rel="noreferrer"
          role="listitem"
          aria-label={`Open ${project.name} on GitHub`}
        >
          <img src={project.image} alt={project.imageAlt} loading="lazy" />
          <div class="project-card__body">
            <h2>{project.name}</h2>
            <p>{project.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .projects-shell > p {
    margin-top: -0.2rem;
    margin-bottom: 1.2rem;
    color: var(--muted);
  }

  .project-deck {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .project-card {
    display: block;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid #21324f;
    background: linear-gradient(180deg, #0a1222 0%, #0f1624 100%);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
    text-decoration: none;
    color: inherit;
    transition: transform 120ms ease, box-shadow 120ms ease,
      border-color 120ms ease;
  }

  .project-card:hover,
  .project-card:focus-visible {
    transform: translateY(-4px);
    border-color: #49c5ff;
    box-shadow: 0 14px 34px rgba(73, 197, 255, 0.25);
    outline: none;
  }

  .project-card img {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    object-fit: cover;
    border-bottom: 1px solid #21324f;
    background: #020912;
  }

  .project-card__body {
    padding: 0.95rem 1rem 1.1rem;
  }

  .project-card h2 {
    margin: 0 0 0.35rem;
    font-size: 1.12rem;
    color: #b8ecff;
  }

  .project-card p {
    margin: 0;
    color: #d3e6f5;
    line-height: 1.4;
  }
</style>
