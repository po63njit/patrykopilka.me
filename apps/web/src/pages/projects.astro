---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'SimpleJim',
    href: 'https://github.com/po63njit/SimpleJim',
    image: '/images/simplejim-broscience.svg',
    description:
      'Kotlin + Compose workout logger with Track/History views, quick lift presets, repeat-last-workout, notes, and offline Room-backed storage.',
    details: [
      { label: 'Stack', value: 'Kotlin • Jetpack Compose • Room' },
      { label: 'Platform', value: 'Android' },
      { label: 'Flow', value: 'Track + History + Repeat Last' },
      { label: 'Data', value: 'Offline-first SQLite persistence' },
      { label: 'Vibe', value: '50% Fact • 50% Magic • 100% Results' },
    ],
  },
  {
    name: 'JamGuard',
    href: 'https://github.com/kyrtapaklipo/JamGuard',
    image: 'https://opengraph.githubassets.com/1/kyrtapaklipo/JamGuard',
    description: 'FPS anti-cheat project focused on reducing unfair play and protecting online matches.',
    details: [
      { label: 'Stack', value: 'Low-level systems + security logic' },
      { label: 'Platform', value: 'Competitive FPS ecosystems' },
      { label: 'Focus', value: 'Cheat detection and prevention' },
      { label: 'Goal', value: 'Fairer online matches' },
      { label: 'Status', value: 'Active GitHub project' },
    ],
  },
];
---

<BaseLayout title="Projects — patrykopilka.me">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

  <section class="projects-solar card">
    <p class="projects-solar__eyebrow">Projects</p>
    <h1>Solarpunk Project Carousel</h1>
    <p class="projects-solar__intro">Swipe through builds, then open any project directly on GitHub.</p>

    <div class="swiper projects-swiper" aria-label="Project carousel">
      <div class="swiper-wrapper">
        {projects.map((project) => (
          <article class="swiper-slide project-slide" style={`--slide-image: url('${project.image}')`}>
            <div class="project-slide__veil">
              <div class="project-slide__headline">
                <h2>{project.name}</h2>
                <p>{project.description}</p>
              </div>
              <div class="project-slide__info" aria-label={`${project.name} highlights`}>
                {project.details.map((item) => (
                  <span title={item.label}>{item.value}</span>
                ))}
              </div>
              <div class="project-slide__actions">
                <a href={project.href} target="_blank" rel="noreferrer" aria-label={`Open ${project.name} on GitHub`}>
                  View on GitHub ↗
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script is:inline>
    const initProjectsSwiper = () => {
      if (!window.Swiper) return;

      new window.Swiper('.projects-swiper', {
        effect: 'coverflow',
        loop: true,
        centeredSlides: true,
        grabCursor: true,
        slidesPerView: 1.15,
        coverflowEffect: {
          rotate: 36,
          stretch: 0,
          depth: 120,
          modifier: 1,
          slideShadows: true,
        },
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        breakpoints: {
          580: { slidesPerView: 1.5 },
          767: { slidesPerView: 2.2 },
          992: { slidesPerView: 2.8 },
          1200: { slidesPerView: 3.2 },
        },
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProjectsSwiper, { once: true });
    } else {
      initProjectsSwiper();
    }
  </script>
</BaseLayout>

<style>
  .projects-solar {
    --solar-leaf: #7ad66f;
    --solar-moss: #3ea95f;
    --solar-sun: #ffd36a;
    --solar-ink: #06100f;
    --solar-night: #0d1a16;
    --solar-text: #ddffe2;
    --solar-muted: #b7dec3;

    background:
      radial-gradient(circle at 12% 10%, rgba(122, 214, 111, 0.2), transparent 40%),
      radial-gradient(circle at 88% 0%, rgba(255, 211, 106, 0.16), transparent 44%),
      linear-gradient(165deg, #12231d 0%, #0d1a16 55%, #111a1a 100%);
    border: 1px solid rgba(122, 214, 111, 0.35);
  }

  .projects-solar__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    color: var(--solar-leaf);
  }

  .projects-solar h1 {
    margin: 0.35rem 0 0.4rem;
    color: #e8ffe6;
  }

  .projects-solar__intro {
    margin: 0 0 1.4rem;
    color: var(--solar-muted);
  }

  .projects-swiper {
    width: 100%;
    padding: 1rem 0 3rem;
  }

  .project-slide {
    width: 360px;
    min-height: 500px;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid rgba(122, 214, 111, 0.35);
    box-shadow: 0 20px 35px rgba(0, 0, 0, 0.45);
    background-image: var(--slide-image);
    background-size: cover;
    background-position: center;
    background-color: #0d1614;
    position: relative;
  }

  .project-slide__veil {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: auto 1fr auto;
    background:
      linear-gradient(180deg, rgba(3, 8, 6, 0.2) 0%, rgba(4, 10, 9, 0.72) 48%, rgba(6, 12, 11, 0.95) 100%),
      linear-gradient(135deg, rgba(122, 214, 111, 0.14), transparent 45%);
    padding: 1rem;
    gap: 0.8rem;
  }

  .project-slide__headline h2 {
    margin: 0;
    font-size: 1.95rem;
    color: #e9ffe8;
    text-shadow: 0 3px 8px rgba(0, 0, 0, 0.5);
  }

  .project-slide__headline p {
    margin: 0.4rem 0 0;
    color: #d4eed8;
    max-width: 30ch;
    line-height: 1.42;
  }

  .project-slide__info {
    align-self: end;
  }

  .project-slide__info span {
    width: 100%;
    margin: 0.24rem 0;
    display: inline-block;
    padding: 0.5rem 0.7rem;
    color: var(--solar-text);
    background: linear-gradient(90deg, rgba(122, 214, 111, 0.2), rgba(255, 211, 106, 0.08));
    border: 1px solid rgba(122, 214, 111, 0.35);
    border-radius: 999px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    box-sizing: border-box;
  }

  .project-slide__actions a {
    width: fit-content;
    text-decoration: none;
    color: var(--solar-ink);
    background: linear-gradient(90deg, var(--solar-leaf), var(--solar-sun));
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.36);
    font-weight: 700;
  }

  .project-slide__actions a:hover,
  .project-slide__actions a:focus-visible {
    filter: brightness(1.06);
    outline: none;
  }

  .swiper-pagination-bullet {
    background: rgba(175, 228, 164, 0.65);
    opacity: 0.55;
    border-radius: 999px;
    transition: all 0.35s ease;
  }

  .swiper-pagination-bullet-active {
    background: var(--solar-sun);
    width: 26px;
    opacity: 1;
  }

  @media (max-width: 520px) {
    .project-slide {
      width: 300px;
      min-height: 480px;
    }

    .project-slide__headline h2 {
      font-size: 1.7rem;
    }
  }
</style>
