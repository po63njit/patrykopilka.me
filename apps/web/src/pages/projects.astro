---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'SimpleJim',
    href: 'https://github.com/po63njit/SimpleJim',
    image: '/images/simplejim-broscience.svg',
    description: 'Kotlin + Compose workout logger with offline-first tracking and history.',
    details: [
      { label: 'Stack', value: 'Kotlin • Compose • Room' },
      { label: 'Platform', value: 'Android' },
      { label: 'Flow', value: 'Track, History, Repeat Last' },
      { label: 'Storage', value: 'SQLite (Room), offline-first' },
      { label: 'Slogan', value: '50% Fact • 50% Magic • 100% Results' },
    ],
  },
  {
    name: 'JamGuard',
    href: 'https://github.com/kyrtapaklipo/JamGuard',
    image: 'https://opengraph.githubassets.com/1/kyrtapaklipo/JamGuard',
    description: 'FPS anti-cheat project focused on fair online matches.',
    details: [
      { label: 'Category', value: 'Anti-cheat / Security' },
      { label: 'Platform', value: 'Competitive FPS' },
      { label: 'Focus', value: 'Detection + prevention' },
      { label: 'Goal', value: 'Reduce unfair advantage' },
      { label: 'Status', value: 'Active project' },
    ],
  },
];
---

<BaseLayout title="Projects — patrykopilka.me">
  <section class="projects-solar card">
    <p class="eyebrow">Projects</p>
    <h1>Solarpunk Project Carousel</h1>
    <p class="intro">Swipe through projects and open them on GitHub.</p>

    <div class="swiper" aria-label="Project cards carousel">
      <div class="swiper-wrapper">
        {projects.map((project) => (
          <article class="swiper-slide" style={`background-image:url('${project.image}')`}>
            <div class="info">
              <h2>{project.name}</h2>
              <p>{project.description}</p>
              {project.details.map((item) => (
                <span title={item.label}>{item.value}</span>
              ))}
              <a href={project.href} target="_blank" rel="noreferrer" aria-label={`Open ${project.name} on GitHub`}>
                View on GitHub ↗
              </a>
            </div>
          </article>
        ))}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </section>

  <script type="module" is:inline>
    import Swiper from 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.mjs';

    const swiper = new Swiper('.swiper', {
      effect: 'coverflow',
      loop: true,
      grabCursor: true,
      centeredSlides: true,
      slidesPerView: '1',
      coverflowEffect: {
        rotate: 50,
        stretch: 0,
        depth: 100,
        modifier: 1,
        slideShadows: true,
      },
      pagination: {
        el: '.swiper-pagination',
      },
      breakpoints: {
        320: {
          slidesPerView: 1.5,
        },
        580: {
          slidesPerView: 2,
        },
        767: {
          slidesPerView: 3,
        },
        992: {
          slidesPerView: 3.5,
        },
        1200: {
          slidesPerView: 4,
        },
        1400: {
          slidesPerView: 4.5,
        },
      },
    });
  </script>
</BaseLayout>

<style>
  @import url('https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css');

  :root {
    --tst: bottom 0.5s ease 0s;
    --dark: #e6e6e6ee;
    --solar-leaf: #7ad66f;
    --solar-sun: #ffd36a;
    --solar-bg: #0e1b16;
    --solar-bg-soft: #132720;
  }

  .projects-solar {
    background:
      radial-gradient(circle at 8% 5%, rgba(122, 214, 111, 0.22), transparent 35%),
      radial-gradient(circle at 85% 0%, rgba(255, 211, 106, 0.18), transparent 45%),
      linear-gradient(160deg, var(--solar-bg) 0%, var(--solar-bg-soft) 100%);
    border: 1px solid rgba(122, 214, 111, 0.33);
  }

  .eyebrow {
    margin: 0;
    color: var(--solar-leaf);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
  }

  h1 {
    margin: 0.35rem 0 0.4rem;
    color: #e8ffe6;
  }

  .intro {
    margin: 0 0 1rem;
    color: #cfe8d0;
  }

  .swiper {
    width: 100%;
    padding-top: 30px;
    padding-bottom: 50px;
  }

  .swiper-slide {
    background-position: center;
    background-size: cover;
    width: 400px;
    height: 500px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(122, 214, 111, 0.4);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.45);
  }

  .swiper-pagination-bullet {
    background: #7ca184;
    transition: all 0.5s ease 0s;
    border-radius: 8px;
  }

  .swiper-pagination-bullet-active {
    background: var(--solar-sun);
    width: 30px;
  }

  .info {
    position: absolute;
    width: calc(100% + 2px);
    height: calc(74% + 2px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0) 0, rgba(11, 19, 15, 0.75) 55px),
      linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(8, 16, 12, 0.96));
    padding: 14px;
    left: 0;
    bottom: calc(-100% - 3px);
    box-sizing: border-box;
    transition: var(--tst);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .swiper-slide-active .info {
    bottom: 0;
    transition: var(--tst);
  }

  .info h2 {
    margin: 0;
    color: #efffec;
    font-size: 1.9rem;
  }

  .info p {
    margin: 0.2rem 0 0.4rem;
    color: #d5f3d5;
    line-height: 1.35;
    font-size: 0.95rem;
  }

  .info span {
    width: 100%;
    margin: 0.2em 0;
    display: inline-block;
    padding: 0.5em 0.65em 0.5em 0.9em;
    box-sizing: border-box;
    color: var(--dark);
    text-transform: uppercase;
    font-size: 0.72rem;
    border-radius: 2em;
    background: linear-gradient(90deg, rgba(122, 214, 111, 0.22), rgba(255, 211, 106, 0.12));
    border: 1px solid rgba(122, 214, 111, 0.38);
  }

  .info a {
    margin-top: 0.55rem;
    width: fit-content;
    text-decoration: none;
    color: #082014;
    background: linear-gradient(90deg, var(--solar-leaf), var(--solar-sun));
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.35rem 0.8rem;
    font-weight: 700;
  }

  .info a:hover,
  .info a:focus-visible {
    filter: brightness(1.08);
    outline: none;
  }
</style>
