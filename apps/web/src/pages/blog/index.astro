---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const rawPosts = await getCollection('blog');

const posts = rawPosts.map((post) => ({
  ...post,
  data: {
    ...post.data,
    tags: (post.data.tags ?? []).map((t) => t.toLowerCase()),
  },
}));

const sorted = posts
  .slice()
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );

const mainPost = sorted[0];

const topics = [
  {
    label: 'Notes & Research',
    key: 'notes-research',
    tag: 'notes',
    subtitle: 'Deep dives and frameworks',
  },
  {
    label: 'Fitness',
    key: 'fitness',
    tag: 'fitness',
    subtitle: 'Training, recovery, routines',
  },
  {
    label: 'Investing',
    key: 'investing',
    tag: 'investing',
    subtitle: 'Process over predictions',
  },
  {
    label: 'Travel',
    key: 'travel',
    tag: 'travel',
    subtitle: 'Places, itineraries, lessons',
  },
];

const categories = topics.map((topic) => {
  const topicPosts = sorted.filter((p) =>
    p.data.tags.includes(topic.tag.toLowerCase()),
  );

  return {
    ...topic,
    posts: topicPosts,
    leadPost: topicPosts[0],
    morePosts: topicPosts.slice(1, 6),
  };
});

const year = new Date().getFullYear();
---

<BaseLayout
  title="Blog — patrykopilka.me"
  description="Writing, notes, and experiments."
>
  <div class="blog-page">
    <section class="blog-banner">
      <div class="blog-banner-logo">
        SIMPLY <span>PATRYK</span>
      </div>
      <p class="blog-banner-tagline">
        Patrykverse — anything that sends me down a deep dive gets posted here.
      </p>
    </section>

    <section class="blog-hero">
      <div class="blog-hero-graphic" aria-hidden="true"></div>
      <div class="blog-hero-overlay">
        <p class="blog-hero-eyebrow">Latest</p>
        <h1 class="blog-hero-title">
          {mainPost ? mainPost.data.title : 'Nothing published… yet.'}
        </h1>
        {mainPost && (
          <p class="blog-hero-meta">
            {new Date(mainPost.data.date).toLocaleDateString(undefined, {
              year: 'numeric',
              month: 'short',
              day: '2-digit',
            })}
            {mainPost.data.tags && mainPost.data.tags.length > 0 && (
              <>
                {' · '}
                <span>{mainPost.data.tags.join(', ')}</span>
              </>
            )}
          </p>
        )}
      </div>
    </section>

    <section class="blog-topic-shell" aria-label="Blog categories">
      <nav class="blog-topic-nav" aria-label="Post categories">
        <div class="blog-topic-nav-header">
          <h2>Blog Control</h2>
          <p>{year} editions</p>
        </div>

        {categories.map((topic, index) => (
          <button
            class={`blog-topic-btn ${index === 0 ? 'active' : ''}`}
            type="button"
            data-topic-btn={topic.key}
            aria-controls={`topic-panel-${topic.key}`}
            aria-selected={index === 0 ? 'true' : 'false'}
            role="tab"
          >
            <span class="blog-topic-btn-index">{String(index + 1).padStart(2, '0')}</span>
            <span class="blog-topic-btn-copy">
              <span class="blog-topic-btn-title">{topic.label}</span>
              <span class="blog-topic-btn-subtitle">{topic.subtitle}</span>
            </span>
            <span class="blog-topic-btn-count">{topic.posts.length}</span>
          </button>
        ))}
      </nav>

      <div class="blog-topic-panels">
        {categories.map((topic, index) => (
          <section
            class={`blog-topic-panel ${index === 0 ? 'active' : ''}`}
            id={`topic-panel-${topic.key}`}
            data-topic-panel={topic.key}
            role="tabpanel"
          >
            <header class="blog-topic-panel-header">
              <p class="blog-topic-panel-kicker">{topic.tag}</p>
              <h2>{topic.label}</h2>
              <p>{topic.subtitle} · {topic.posts.length} post{topic.posts.length === 1 ? '' : 's'}.</p>
            </header>

            {topic.leadPost ? (
              <article class="blog-topic-lead">
                <h3><a href={`/blog/${topic.leadPost.slug}`}>{topic.leadPost.data.title}</a></h3>
                <p class="blog-item-meta">
                  {new Date(topic.leadPost.data.date).toLocaleDateString(undefined, {
                    year: 'numeric',
                    month: 'short',
                    day: '2-digit',
                  })}
                </p>
                {topic.leadPost.data.description && (
                  <p class="blog-topic-lead-excerpt">{topic.leadPost.data.description}</p>
                )}
              </article>
            ) : (
              <p class="blog-item-meta">No posts in this category yet. New notes soon.</p>
            )}

            {topic.morePosts.length > 0 && (
              <ul class="blog-topic-list">
                {topic.morePosts.map((post) => (
                  <li>
                    <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                    <span>
                      {new Date(post.data.date).toLocaleDateString(undefined, {
                        year: 'numeric',
                        month: 'short',
                        day: '2-digit',
                      })}
                    </span>
                  </li>
                ))}
              </ul>
            )}
          </section>
        ))}
      </div>
    </section>
  </div>

  <script>
    const topicButtons = Array.from(document.querySelectorAll('[data-topic-btn]'));
    const topicPanels = Array.from(document.querySelectorAll('[data-topic-panel]'));

    const setActiveTopic = (topicKey) => {
      topicButtons.forEach((btn) => {
        const active = btn.getAttribute('data-topic-btn') === topicKey;
        btn.classList.toggle('active', active);
        btn.setAttribute('aria-selected', String(active));
      });

      topicPanels.forEach((panel) => {
        panel.classList.toggle('active', panel.getAttribute('data-topic-panel') === topicKey);
      });
    };

    topicButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const topicKey = btn.getAttribute('data-topic-btn');
        if (topicKey) setActiveTopic(topicKey);
      });
    });
  </script>
</BaseLayout>
