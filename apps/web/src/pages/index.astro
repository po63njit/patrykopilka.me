---
import BaseLayout from '../layouts/BaseLayout.astro';
import SaturnLink from '../components/SaturnLink.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const apiBase =
  import.meta.env.PUBLIC_API_BASE || 'https://api.patrykopilka.me';

const latestPosts = posts
  .slice()
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 5);
---

<BaseLayout
  title="Home — patrykopilka.me"
  description="Patryk Opilka — blog, resume, and experiments."
>
<section class="hero">
  <!-- Rays background (full-screen, behind everything) -->
  <div class="a-rays" aria-hidden="true"></div>

  <!-- Foreground content -->
  <div class="hero-inner">
    <canvas class="ferro-canvas" aria-hidden="true"></canvas>
    <nav class="planet-nav" aria-label="Main sections">
      <SaturnLink href="/blog" label="Blog" variant="earth" className="planet-link--blog" />
      <SaturnLink href="/resume" label="Resume" variant="venus" className="planet-link--resume" />
      <SaturnLink href="/about" label="About" variant="saturn" className="planet-link--about" />
      <SaturnLink href="/projects" label="Projects" variant="jupiter" className="planet-link--projects" />
    </nav>

    <p class="hero-tagline">
      Computer Engineering student building from the metal up: RISC-V, GNSS,
      ML, and weird systems and hardware experiments.
      <br />
      {apiBase ? (
        <a
          href={`${apiBase}/health`}
          target="_blank"
          rel="noreferrer"
          class="hero-api-link"
        >
          Check API health
        </a>
      ) : (
        <span class="muted">
          Set PUBLIC_API_BASE to enable API link.
        </span>
      )}
    </p>
  </div>
</section>




  <section class="card latest-posts">
    <h2>Latest posts</h2>
    {latestPosts.length === 0 ? (
      <p class="muted">Nothing published yet. Soon™.</p>
    ) : (
      <>
        <ul>
          {latestPosts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}`}>{p.data.title}</a>{' '}
              <span class="muted">
                —{' '}
                {new Date(p.data.date).toLocaleDateString(undefined, {
                  year: 'numeric',
                  month: 'short',
                  day: '2-digit',
                })}
              </span>
            </li>
          ))}
        </ul>
        <p>
          <a href="/blog">All posts →</a>
        </p>
      </>
    )}
  </section>
  <script>
  class Rays {
    constructor(container) {
      this.container = container;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.rays = [];
      this.init();
    }

    init() {
      this.resizeHandler();
      window.addEventListener("resize", this.resizeHandler.bind(this));
      requestAnimationFrame(this.tick.bind(this));
    }

    resizeHandler() {
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.emit();
    }

    emit() {
      this.rays = [];
      this.totalRays = this.height * 0.75;

      for (let i = 0; i < this.totalRays; i++) {
        this.rays.push(new Ray(this));
      }
    }

    tick() {
      let path = "";
      this.rays.forEach((ray) => {
        ray.tick();
        path += ray.d;
      });

      this.container.style.clipPath = `path("${path}")`;
      requestAnimationFrame(this.tick.bind(this));
    }
  }

  class Ray {
    constructor(emitter) {
      this.emitter = emitter;
      const gap = 12;

      this.x = Math.random() * this.emitter.width;
      this.y =
        Math.floor(Math.random() * (this.emitter.height / gap + 1)) * gap;

      this.width = 50 * Math.random();
      this.velocity = 0.25 + this.width / 50;

      this.d = "";
    }

    update() {
      this.x += this.velocity;
      if (this.x > this.emitter.width) {
        this.x = -this.width;
      }
    }

    draw() {
      this.d = `M ${this.x},${this.y} h ${this.width} v 1 h -${this.width} z `;
    }

    tick() {
      this.update();
      this.draw();
    }
  }

  window.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector(".a-rays");
    if (container) new Rays(container);

    const ferroCanvas = document.querySelector(".ferro-canvas");
    const hero = document.querySelector(".hero");
    if (ferroCanvas && hero) new FerroFluid(ferroCanvas, hero);
  });

  class FerroFluid {
    constructor(canvas, hero) {
      this.canvas = canvas;
      this.ctx = this.canvas.getContext("2d");
      this.hero = hero;
      this.dpr = window.devicePixelRatio || 1;
      this.center = { x: 0, y: 0 };
      this.baseRadius = 80;
      this.time = 0;
      this.targetStrength = 0;
      this.strength = 0;
      this.targetPoint = { x: 0, y: 0 };
      this.magnet = null;

      this.resize = this.resize.bind(this);
      this.handlePointer = this.handlePointer.bind(this);
      this.handleClick = this.handleClick.bind(this);
      this.tick = this.tick.bind(this);

      this.resize();
      window.addEventListener("resize", this.resize);
      this.hero.addEventListener("pointermove", this.handlePointer);
      this.hero.addEventListener("pointerdown", this.handleClick);
      requestAnimationFrame(this.tick);
    }

    resize() {
      const size = Math.min(window.innerWidth * 0.35, 360);
      this.baseRadius = size * 0.26;
      this.canvas.width = size * this.dpr;
      this.canvas.height = size * this.dpr;
      this.canvas.style.width = `${size}px`;
      this.canvas.style.height = `${size}px`;
      this.ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
      this.center.x = size / 2;
      this.center.y = size / 2;
    }

    handlePointer(event) {
      const target = event.target instanceof Element ? event.target : null;
      const planet = target ? target.closest(".planet-link") : null;
      if (planet) {
        const rect = planet.getBoundingClientRect();
        const heroRect = this.hero.getBoundingClientRect();
        this.magnet = {
          x: rect.left + rect.width / 2 - heroRect.left,
          y: rect.top + rect.height / 2 - heroRect.top,
        };
        this.targetStrength = 1;
        return;
      }

      this.targetStrength = 0;
      this.magnet = null;
    }

    handleClick(event) {
      const heroRect = this.hero.getBoundingClientRect();
      this.magnet = {
        x: event.clientX - heroRect.left,
        y: event.clientY - heroRect.top,
      };
      this.targetStrength = 1.4;
    }

    tick() {
      this.time += 0.015;
      this.strength += (this.targetStrength - this.strength) * 0.08;
      this.targetStrength *= 0.985;

      const rect = this.canvas.getBoundingClientRect();
      const heroRect = this.hero.getBoundingClientRect();
      const cx = rect.left + rect.width / 2 - heroRect.left;
      const cy = rect.top + rect.height / 2 - heroRect.top;

      if (this.magnet) {
        this.targetPoint.x = this.magnet.x - cx;
        this.targetPoint.y = this.magnet.y - cy;
      } else {
        this.targetPoint.x *= 0.92;
        this.targetPoint.y *= 0.92;
      }

      this.draw();
      requestAnimationFrame(this.tick);
    }

    draw() {
      const ctx = this.ctx;
      const w = this.canvas.width / this.dpr;
      const h = this.canvas.height / this.dpr;
      ctx.clearRect(0, 0, w, h);

      const angleToMagnet = Math.atan2(this.targetPoint.y, this.targetPoint.x);
      const dist = Math.hypot(this.targetPoint.x, this.targetPoint.y);
      const spikeInfluence = Math.min(1, dist / (w * 0.45)) * this.strength;
      const points = 180;

      ctx.beginPath();
      for (let i = 0; i <= points; i++) {
        const t = (i / points) * Math.PI * 2;
        const wobble =
          Math.sin(t * 12 + this.time * 3.2) * 6 +
          Math.sin(t * 18 - this.time * 4.1) * 4;
        const delta = Math.abs(Math.atan2(Math.sin(t - angleToMagnet), Math.cos(t - angleToMagnet)));
        const directionPull = Math.max(0, 1 - delta / 1.0);
        const spike = Math.pow(directionPull, 2.2) * this.baseRadius * 0.95 * spikeInfluence;

        const radius = this.baseRadius + wobble + spike;
        const x = this.center.x + Math.cos(t) * radius;
        const y = this.center.y + Math.sin(t) * radius;

        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();

      const bodyGrad = ctx.createRadialGradient(
        this.center.x - this.baseRadius * 0.45,
        this.center.y - this.baseRadius * 0.52,
        this.baseRadius * 0.14,
        this.center.x,
        this.center.y + this.baseRadius * 0.15,
        this.baseRadius * 1.35,
      );
      bodyGrad.addColorStop(0, "#1a1a1a");
      bodyGrad.addColorStop(0.25, "#050505");
      bodyGrad.addColorStop(0.65, "#010101");
      bodyGrad.addColorStop(1, "#000000");
      ctx.fillStyle = bodyGrad;
      ctx.fill();

      const rimGrad = ctx.createLinearGradient(
        this.center.x - this.baseRadius,
        this.center.y - this.baseRadius,
        this.center.x + this.baseRadius,
        this.center.y + this.baseRadius,
      );
      rimGrad.addColorStop(0, "rgba(255,255,255,0.18)");
      rimGrad.addColorStop(0.5, "rgba(255,255,255,0.03)");
      rimGrad.addColorStop(1, "rgba(0,0,0,0.55)");
      ctx.strokeStyle = rimGrad;
      ctx.lineWidth = 1.2;
      ctx.stroke();

      const coreShade = ctx.createRadialGradient(
        this.center.x + this.baseRadius * 0.15,
        this.center.y + this.baseRadius * 0.25,
        this.baseRadius * 0.2,
        this.center.x,
        this.center.y,
        this.baseRadius * 1.2,
      );
      coreShade.addColorStop(0, "rgba(0,0,0,0)");
      coreShade.addColorStop(1, "rgba(0,0,0,0.7)");
      ctx.fillStyle = coreShade;
      ctx.fill();

      const highlight = ctx.createRadialGradient(
        this.center.x - this.baseRadius * 0.36,
        this.center.y - this.baseRadius * 0.4,
        this.baseRadius * 0.08,
        this.center.x - this.baseRadius * 0.3,
        this.center.y - this.baseRadius * 0.35,
        this.baseRadius * 0.52,
      );
      highlight.addColorStop(0, "rgba(255,255,255,0.24)");
      highlight.addColorStop(0.45, "rgba(255,255,255,0.08)");
      highlight.addColorStop(1, "rgba(255,255,255,0)");
      ctx.globalCompositeOperation = "screen";
      ctx.fillStyle = highlight;
      ctx.fill();
      ctx.globalCompositeOperation = "source-over";
    }
  }
</script>

</BaseLayout>
