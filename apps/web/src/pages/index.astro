---
import BaseLayout from '../layouts/BaseLayout.astro';
import SaturnLink from '../components/SaturnLink.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const apiBase =
  import.meta.env.PUBLIC_API_BASE || 'https://api.patrykopilka.me';

const latestPosts = posts
  .slice()
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 5);
---

<BaseLayout
  title="Home — patrykopilka.me"
  description="Patryk Opilka — blog, resume, and experiments."
>
<section class="hero">
  <!-- Rays background (full-screen, behind everything) -->
  <div class="a-rays" aria-hidden="true"></div>

  <!-- Foreground content -->
  <div class="hero-inner">
    <canvas class="ferro-canvas" aria-hidden="true"></canvas>
    <nav class="planet-nav" aria-label="Main sections">
      <SaturnLink href="/blog" label="Blog" variant="earth" className="planet-link--blog" />
      <SaturnLink href="/resume" label="Resume" variant="venus" className="planet-link--resume" />
      <SaturnLink href="/about" label="About" variant="saturn" className="planet-link--about" />
      <SaturnLink href="/projects" label="Projects" variant="jupiter" className="planet-link--projects" />
    </nav>

    <p class="hero-tagline">
      Computer Engineering student building from the metal up: RISC-V, GNSS,
      ML, and weird systems and hardware experiments.
      <br />
      {apiBase ? (
        <a
          href={`${apiBase}/health`}
          target="_blank"
          rel="noreferrer"
          class="hero-api-link"
        >
          Check API health
        </a>
      ) : (
        <span class="muted">
          Set PUBLIC_API_BASE to enable API link.
        </span>
      )}
    </p>
  </div>
</section>




  <section class="card latest-posts">
    <h2>Latest posts</h2>
    {latestPosts.length === 0 ? (
      <p class="muted">Nothing published yet. Soon™.</p>
    ) : (
      <>
        <ul>
          {latestPosts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}`}>{p.data.title}</a>{' '}
              <span class="muted">
                —{' '}
                {new Date(p.data.date).toLocaleDateString(undefined, {
                  year: 'numeric',
                  month: 'short',
                  day: '2-digit',
                })}
              </span>
            </li>
          ))}
        </ul>
        <p>
          <a href="/blog">All posts →</a>
        </p>
      </>
    )}
  </section>
  <script type="importmap">
  {
    "imports": {
      "three": "https://unpkg.com/three@0.162.0/build/three.module.js",
      "three/addons/controls/OrbitControls.js": "https://unpkg.com/three@0.162.0/examples/jsm/controls/OrbitControls.js"
    }
  }
  </script>

  <script type="module">
  import * as THREE from "three";

  class Rays {
    constructor(container) {
      this.container = container;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.rays = [];
      this.resizeHandler = this.resizeHandler.bind(this);
      this.tick = this.tick.bind(this);
      this.resizeHandler();
      window.addEventListener("resize", this.resizeHandler);
      requestAnimationFrame(this.tick);
    }

    resizeHandler() {
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.rays = [];
      const totalRays = this.height * 0.75;
      for (let i = 0; i < totalRays; i++) this.rays.push(new Ray(this));
    }

    tick() {
      let path = "";
      this.rays.forEach((ray) => {
        ray.tick();
        path += ray.d;
      });
      this.container.style.clipPath = `path("${path}")`;
      requestAnimationFrame(this.tick);
    }
  }

  class Ray {
    constructor(emitter) {
      this.emitter = emitter;
      const gap = 12;
      this.x = Math.random() * this.emitter.width;
      this.y = Math.floor(Math.random() * (this.emitter.height / gap + 1)) * gap;
      this.width = 50 * Math.random();
      this.velocity = 0.25 + this.width / 50;
      this.d = "";
    }

    tick() {
      this.x += this.velocity;
      if (this.x > this.emitter.width) this.x = -this.width;
      this.d = `M ${this.x},${this.y} h ${this.width} v 1 h -${this.width} z `;
    }
  }

  class HypercubeHero {
    constructor(canvas, hero) {
      this.canvas = canvas;
      this.hero = hero;
      this.duration = 16000;
      this.attractor = new THREE.Vector3(0, 0, 0);
      this.attractorTarget = new THREE.Vector3(0, 0, 0);
      this.targetStrength = 0;
      this.strength = 0;
      this.floatProgress = 0;
      this.floatDirection = 0;
      this.linkAttractorActive = false;

      this.scene = new THREE.Scene();
      this.camera = new THREE.PerspectiveCamera(50, 1, 0.1, 2000);
      this.camera.position.set(0, 0, 6);
      this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, antialias: true, alpha: true });
      this.renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
      this.renderer.setClearColor(0x000000, 0);

      this.buildTesseract();
      this.bindEvents();
      this.resize();
      this.animate = this.animate.bind(this);
      requestAnimationFrame(this.animate);
    }

    random() {
      return crypto.getRandomValues(new Uint32Array(1))[0] / 2 ** 32;
    }

    buildTesseract() {
      const particlesPerEdge = 200;
      const sizeOut = 1;
      const sizeIn = 0.5;
      const cubeEdges = [[0, 1], [1, 3], [3, 2], [2, 0], [4, 5], [5, 7], [7, 6], [6, 4], [0, 4], [1, 5], [2, 6], [3, 7]];
      const unitCorners = [];
      const geo = new THREE.BufferGeometry();
      const totalParticles = cubeEdges.length * particlesPerEdge;
      const posStart = new Float32Array(totalParticles * 3);
      const posEnd = new Float32Array(totalParticles * 3);
      const offsets = new Float32Array(totalParticles);
      let pIdx = 0;

      for (let x = -1; x <= 1; x += 2) {
        for (let y = -1; y <= 1; y += 2) {
          for (let z = -1; z <= 1; z += 2) unitCorners.push(new THREE.Vector3(x, y, z));
        }
      }

      cubeEdges.forEach(([cornerA, cornerB]) => {
        const vA = unitCorners[cornerA];
        const vB = unitCorners[cornerB];
        for (let p = 0; p < particlesPerEdge; p++) {
          const t = p / particlesPerEdge;
          const edgePoint = new THREE.Vector3().lerpVectors(vA, vB, t);
          const start = edgePoint.clone().multiplyScalar(sizeOut);
          const end = edgePoint.clone().multiplyScalar(sizeIn);
          const inward = pIdx % 2 === 0;

          const idx = pIdx * 3;
          posStart[idx] = inward ? start.x : end.x;
          posStart[idx + 1] = inward ? start.y : end.y;
          posStart[idx + 2] = inward ? start.z : end.z;
          posEnd[idx] = inward ? end.x : start.x;
          posEnd[idx + 1] = inward ? end.y : start.y;
          posEnd[idx + 2] = inward ? end.z : start.z;
          offsets[pIdx] = this.random();
          pIdx++;
        }
      });

      geo.setAttribute("position", new THREE.BufferAttribute(posStart, 3));
      geo.setAttribute("targetPos", new THREE.BufferAttribute(posEnd, 3));
      geo.setAttribute("offset", new THREE.BufferAttribute(offsets, 1));

      this.mat = new THREE.ShaderMaterial({
        uniforms: {
          uTime: { value: 0 },
          uColor: { value: new THREE.Color(0x57ffd7) },
          uResolution: { value: window.innerHeight * Math.min(window.devicePixelRatio || 1, 2) },
          uStrength: { value: 0 },
          uAttractor: { value: new THREE.Vector3(0, 0, 0) },
          uFloatProgress: { value: 0 },
        },
        vertexShader: `
          uniform float uTime;
          uniform float uResolution;
          uniform float uStrength;
          uniform float uFloatProgress;
          uniform vec3 uAttractor;
          attribute vec3 targetPos;
          attribute float offset;
          float cubicBezierX(float t, float x1, float x2) { return 3.0 * (1.0 - t) * (1.0 - t) * t * x1 + 3.0 * (1.0 - t) * t * t * x2 + t * t * t; }
          float cubicBezierDX(float t, float x1, float x2) { return 3.0 * (1.0 - t) * (1.0 - t) * x1 + 6.0 * (1.0 - t) * t * (x2 - x1) + 3.0 * t * t * (1.0 - x2); }
          float cubicBezierEase(float x) {
            float x1 = 0.37; float y1 = 0.0; float x2 = 0.63; float y2 = 1.0; float t = x;
            for (int i = 0; i < 8; i++) { float err = cubicBezierX(t, x1, x2) - x; float dt = cubicBezierDX(t, x1, x2); if (abs(dt) < 1e-6) break; t -= err / dt; t = clamp(t, 0.0, 1.0); }
            return 3.0 * (1.0 - t) * (1.0 - t) * t * y1 + 3.0 * (1.0 - t) * t * t * y2 + t * t * t;
          }
          void main() {
            float raw = mod(uTime * 0.5 + offset, 2.0);
            float leg = raw < 1.0 ? cubicBezierEase(raw) : 1.0 - cubicBezierEase(raw - 1.0);
            vec3 midDir = normalize(position + targetPos);
            float bulge = sin(leg * 3.14159265) * (0.1 + uStrength * 0.06);
            vec3 currentPos = mix(position, targetPos, leg) + midDir * bulge;
            vec3 toAttractor = uAttractor - currentPos;
            float distanceToAttractor = length(toAttractor);
            float attractionFalloff = exp(-distanceToAttractor * 3.2);
            float pulse = 0.85 + 0.15 * sin(uTime * 7.0 + offset * 35.0);
            float attractionStrength = uStrength * (0.35 + attractionFalloff * 2.1) * pulse;
            vec3 attractionPos = currentPos + toAttractor * attractionStrength;
            float launchDelay = fract(offset * 47.19) * 0.45;
            float travel = smoothstep(launchDelay, 1.0, uFloatProgress);
            vec3 drift = vec3(
              sin(uTime * 2.3 + offset * 78.0),
              cos(uTime * 2.1 + offset * 61.0),
              sin(uTime * 1.8 + offset * 39.0)
            ) * 0.08;
            vec3 floatingPos = mix(currentPos, attractionPos, travel) + drift * travel;
            currentPos = mix(currentPos, floatingPos, uStrength);
            vec4 mvPosition = modelViewMatrix * vec4(currentPos, 1.0);
            gl_PointSize = (uResolution / 50.0) * (1.0 / -mvPosition.z);
            gl_Position = projectionMatrix * mvPosition;
          }
        `,
        fragmentShader: `
          uniform vec3 uColor;
          void main() {
            if (length(gl_PointCoord - vec2(0.5)) > 0.5) discard;
            gl_FragColor = vec4(uColor, 1.0);
          }
        `,
        transparent: true,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });

      this.tesseract = new THREE.Points(geo, this.mat);
      this.tesseract.rotation.x = Math.sin(45 * Math.PI / 180);
      this.scene.add(this.tesseract);
    }

    bindEvents() {
      this.resize = this.resize.bind(this);
      window.addEventListener("resize", this.resize);
      const nav = this.hero.querySelector(".planet-nav");
      if (nav instanceof HTMLElement) {
        nav.addEventListener("pointerdown", (event) => {
          const clickedPlanet = event.target instanceof Element ? event.target.closest(".planet-link") : null;
          if (clickedPlanet) return;
          this.activateFromPointer(event, 1.0);
        });
      }
      window.addEventListener("pointerup", () => {
        if (!this.linkAttractorActive) this.releaseAttractor();
      });
      this.hero.querySelectorAll(".planet-link").forEach((planet) => {
        planet.addEventListener("pointerenter", (e) => this.activateLinkAttractor(e, 0.9));
        planet.addEventListener("pointerdown", (e) => this.activateLinkAttractor(e, 1.2));
        planet.addEventListener("focus", (e) => this.activateLinkAttractor(e, 1.0));
        planet.addEventListener("pointerleave", () => this.deactivateLinkAttractor());
        planet.addEventListener("blur", () => this.deactivateLinkAttractor());
      });
    }

    normalizeToHero(x, y) {
      const heroRect = this.hero.getBoundingClientRect();
      const nx = ((x - heroRect.left) / heroRect.width) * 2 - 1;
      const ny = -((((y - heroRect.top) / heroRect.height) * 2) - 1);
      return new THREE.Vector3(nx * 0.9, ny * 0.72, 0);
    }

    activateLinkAttractor(event, strength) {
      const target = event.currentTarget instanceof Element ? event.currentTarget : null;
      if (!target) return;
      const rect = target.getBoundingClientRect();
      this.attractorTarget.copy(this.normalizeToHero(rect.left + rect.width / 2, rect.top + rect.height / 2));
      this.targetStrength = strength;
      this.floatDirection = 1;
      this.linkAttractorActive = true;
    }

    deactivateLinkAttractor() {
      this.linkAttractorActive = false;
      this.releaseAttractor();
    }

    activateFromPointer(event, strength) {
      this.attractorTarget.copy(this.normalizeToHero(event.clientX, event.clientY));
      this.targetStrength = strength;
      this.floatDirection = 1;
    }

    releaseAttractor() {
      this.targetStrength = 0;
      this.floatDirection = -1;
    }

    resize() {
      const size = Math.min(window.innerWidth * 0.38, 420);
      this.canvas.style.width = `${size}px`;
      this.canvas.style.height = `${size}px`;
      this.renderer.setSize(size, size, false);
      this.camera.aspect = 1;
      this.camera.updateProjectionMatrix();
      this.mat.uniforms.uResolution.value = size * Math.min(window.devicePixelRatio || 1, 2);
    }

    animate(time) {
      requestAnimationFrame(this.animate);
      this.strength += (this.targetStrength - this.strength) * 0.08;
      this.targetStrength *= 0.985;
      this.attractor.lerp(this.attractorTarget, 0.16);
      this.floatProgress = THREE.MathUtils.clamp(this.floatProgress + this.floatDirection * 0.03, 0, 1);
      if (this.floatProgress === 0 && this.targetStrength < 0.02) this.floatDirection = 0;

      const msToSeconds = this.duration / 1e3;
      this.tesseract.rotation.y = (time / 1e3) * (Math.PI * 2 / msToSeconds);
      this.tesseract.rotation.y %= Math.PI * 2;
      this.mat.uniforms.uTime.value = time / 1e3;
      this.mat.uniforms.uStrength.value = this.strength;
      this.mat.uniforms.uAttractor.value.copy(this.attractor);
      this.mat.uniforms.uFloatProgress.value = this.floatProgress;

      this.renderer.render(this.scene, this.camera);
    }
  }

  window.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector(".a-rays");
    if (container) new Rays(container);

    const ferroCanvas = document.querySelector(".ferro-canvas");
    const hero = document.querySelector(".hero");
    if (!(ferroCanvas instanceof HTMLCanvasElement) || !(hero instanceof HTMLElement)) return;

    try {
      new HypercubeHero(ferroCanvas, hero);
    } catch (error) {
      console.error("Hypercube init failed:", error);
    }
  });
  </script>

</BaseLayout>
