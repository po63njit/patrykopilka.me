---
import BaseLayout from '../layouts/BaseLayout.astro';
import SaturnLink from '../components/SaturnLink.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const apiBase =
  import.meta.env.PUBLIC_API_BASE || 'https://api.patrykopilka.me';

const latestPosts = posts
  .slice()
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 5);
---

<BaseLayout
  title="Home — patrykopilka.me"
  description="Patryk Opilka — blog, resume, and experiments."
>
<section class="hero">
  <!-- Rays background (full-screen, behind everything) -->
  <div class="a-rays" aria-hidden="true"></div>

  <!-- Foreground content -->
  <div class="hero-inner">
    <canvas class="ferro-canvas" aria-hidden="true"></canvas>
    <nav class="planet-nav" aria-label="Main sections">
      <SaturnLink href="/blog" label="Blog" variant="earth" className="planet-link--blog" />
      <SaturnLink href="/resume" label="Resume" variant="venus" className="planet-link--resume" />
      <SaturnLink href="/about" label="About" variant="saturn" className="planet-link--about" />
      <SaturnLink href="/projects" label="Projects" variant="jupiter" className="planet-link--projects" />
    </nav>

    <p class="hero-tagline">
      Computer Engineering student building from the metal up: RISC-V, GNSS,
      ML, and weird systems and hardware experiments.
      <br />
      {apiBase ? (
        <a
          href={`${apiBase}/health`}
          target="_blank"
          rel="noreferrer"
          class="hero-api-link"
        >
          Check API health
        </a>
      ) : (
        <span class="muted">
          Set PUBLIC_API_BASE to enable API link.
        </span>
      )}
    </p>
  </div>
</section>




  <section class="card latest-posts">
    <h2>Latest posts</h2>
    {latestPosts.length === 0 ? (
      <p class="muted">Nothing published yet. Soon™.</p>
    ) : (
      <>
        <ul>
          {latestPosts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}`}>{p.data.title}</a>{' '}
              <span class="muted">
                —{' '}
                {new Date(p.data.date).toLocaleDateString(undefined, {
                  year: 'numeric',
                  month: 'short',
                  day: '2-digit',
                })}
              </span>
            </li>
          ))}
        </ul>
        <p>
          <a href="/blog">All posts →</a>
        </p>
      </>
    )}
  </section>
  <script type="module">
  let THREE;
  let EffectComposer;
  let RenderPass;
  let UnrealBloomPass;

  class Rays {
    constructor(container) {
      this.container = container;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.rays = [];
      this.init();
    }

    init() {
      this.resizeHandler();
      window.addEventListener("resize", this.resizeHandler.bind(this));
      requestAnimationFrame(this.tick.bind(this));
    }

    resizeHandler() {
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.emit();
    }

    emit() {
      this.rays = [];
      this.totalRays = this.height * 0.75;

      for (let i = 0; i < this.totalRays; i++) {
        this.rays.push(new Ray(this));
      }
    }

    tick() {
      let path = "";
      this.rays.forEach((ray) => {
        ray.tick();
        path += ray.d;
      });

      this.container.style.clipPath = `path("${path}")`;
      requestAnimationFrame(this.tick.bind(this));
    }
  }

  class Ray {
    constructor(emitter) {
      this.emitter = emitter;
      const gap = 12;

      this.x = Math.random() * this.emitter.width;
      this.y =
        Math.floor(Math.random() * (this.emitter.height / gap + 1)) * gap;

      this.width = 50 * Math.random();
      this.velocity = 0.25 + this.width / 50;
      this.d = "";
    }

    update() {
      this.x += this.velocity;
      if (this.x > this.emitter.width) {
        this.x = -this.width;
      }
    }

    draw() {
      this.d = `M ${this.x},${this.y} h ${this.width} v 1 h -${this.width} z `;
    }

    tick() {
      this.update();
      this.draw();
    }
  }

  class FerroFluid {
    constructor(canvas, hero) {
      this.canvas = canvas;
      this.hero = hero;
      this.clock = new THREE.Clock();
      this.pointer = new THREE.Vector2(0, 0);
      this.magnet = new THREE.Vector2(0, 0);
      this.magnetStrength = 0;
      this.targetStrength = 0;

      this.params = {
        radius: 1.45,
        displacementStrength: 0.24,
        noiseScale: 2.4,
        bloomIntensity: 0.85,
        colorA: "#010708",
        colorB: "#0a2628",
        highlight: "#53f2ce",
      };

      this.resize = this.resize.bind(this);
      this.tick = this.tick.bind(this);
      this.handlePointerMove = this.handlePointerMove.bind(this);
      this.handlePlanetActivate = this.handlePlanetActivate.bind(this);
      this.handlePlanetLeave = this.handlePlanetLeave.bind(this);

      this.init();
      this.bindEvents();
      this.resize();
      requestAnimationFrame(this.tick);
    }

    init() {
      this.scene = new THREE.Scene();
      this.camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
      this.camera.position.set(0, 0, 5.4);

      this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, alpha: true, antialias: true });
      this.renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));

      this.composer = new EffectComposer(this.renderer);
      this.composer.addPass(new RenderPass(this.scene, this.camera));
      this.bloomPass = new UnrealBloomPass(new THREE.Vector2(1, 1), this.params.bloomIntensity, 0.5, 0.2);
      this.composer.addPass(this.bloomPass);

      const geometry = new THREE.SphereGeometry(this.params.radius, 96, 96);
      const material = new THREE.ShaderMaterial({
        uniforms: {
          time: { value: 0 },
          noiseScale: { value: this.params.noiseScale },
          displacementStrength: { value: this.params.displacementStrength },
          magnetDir: { value: new THREE.Vector3(0, 0, 1) },
          magnetStrength: { value: 0 },
          colorA: { value: new THREE.Color(this.params.colorA) },
          colorB: { value: new THREE.Color(this.params.colorB) },
          highlight: { value: new THREE.Color(this.params.highlight) },
        },
        vertexShader: `
          uniform float time;
          uniform float noiseScale;
          uniform float displacementStrength;
          uniform vec3 magnetDir;
          uniform float magnetStrength;
          varying vec3 vNormal;
          varying vec3 vWorld;
          varying float vMagnet;

          vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec4 mod289(vec4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec4 permute(vec4 x) { return mod289(((x * 34.0) + 1.0) * x); }
          vec4 taylorInvSqrt(vec4 r) { return 1.79284291400159 - 0.85373472095314 * r; }

          float snoise(vec3 v) {
            const vec2 C = vec2(1.0 / 6.0, 1.0 / 3.0);
            const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);
            vec3 i = floor(v + dot(v, C.yyy));
            vec3 x0 = v - i + dot(i, C.xxx);
            vec3 g = step(x0.yzx, x0.xyz);
            vec3 l = 1.0 - g;
            vec3 i1 = min(g.xyz, l.zxy);
            vec3 i2 = max(g.xyz, l.zxy);
            vec3 x1 = x0 - i1 + C.xxx;
            vec3 x2 = x0 - i2 + C.yyy;
            vec3 x3 = x0 - D.yyy;
            i = mod289(i);
            vec4 p = permute(permute(permute(i.z + vec4(0.0, i1.z, i2.z, 1.0)) + i.y + vec4(0.0, i1.y, i2.y, 1.0)) + i.x + vec4(0.0, i1.x, i2.x, 1.0));
            float n_ = 0.142857142857;
            vec3 ns = n_ * D.wyz - D.xzx;
            vec4 j = p - 49.0 * floor(p * ns.z * ns.z);
            vec4 x_ = floor(j * ns.z);
            vec4 y_ = floor(j - 7.0 * x_);
            vec4 x = x_ * ns.x + ns.yyyy;
            vec4 y = y_ * ns.x + ns.yyyy;
            vec4 h = 1.0 - abs(x) - abs(y);
            vec4 b0 = vec4(x.xy, y.xy);
            vec4 b1 = vec4(x.zw, y.zw);
            vec4 s0 = floor(b0) * 2.0 + 1.0;
            vec4 s1 = floor(b1) * 2.0 + 1.0;
            vec4 sh = -step(h, vec4(0.0));
            vec4 a0 = b0.xzyw + s0.xzyw * sh.xxyy;
            vec4 a1 = b1.xzyw + s1.xzyw * sh.zzww;
            vec3 p0 = vec3(a0.xy, h.x);
            vec3 p1 = vec3(a0.zw, h.y);
            vec3 p2 = vec3(a1.xy, h.z);
            vec3 p3 = vec3(a1.zw, h.w);
            vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2,p2), dot(p3,p3)));
            p0 *= norm.x;
            p1 *= norm.y;
            p2 *= norm.z;
            p3 *= norm.w;
            vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
            m = m * m;
            return 42.0 * dot(m * m, vec4(dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3)));
          }

          void main() {
            vec3 n = normalize(normal);
            float n1 = snoise(n * noiseScale + vec3(time * 0.9));
            float n2 = snoise(n * (noiseScale * 2.0) - vec3(time * 1.3));
            float fluid = (n1 * 0.65 + n2 * 0.35) * displacementStrength;
            float attract = max(dot(n, normalize(magnetDir)), 0.0);
            float pull = pow(attract, 4.0) * magnetStrength;

            vec3 displaced = position + n * (fluid + pull * 0.72);
            vMagnet = pull;

            vec4 world = modelMatrix * vec4(displaced, 1.0);
            vWorld = world.xyz;
            vNormal = normalize(normalMatrix * n);
            gl_Position = projectionMatrix * viewMatrix * world;
          }
        `,
        fragmentShader: `
          uniform vec3 colorA;
          uniform vec3 colorB;
          uniform vec3 highlight;
          varying vec3 vNormal;
          varying vec3 vWorld;
          varying float vMagnet;

          void main() {
            vec3 lightDir = normalize(vec3(-0.45, 0.8, 0.55));
            float diff = max(dot(normalize(vNormal), lightDir), 0.0);
            float fresnel = pow(1.0 - max(dot(normalize(vNormal), normalize(-vWorld)), 0.0), 2.8);

            vec3 fluidTint = mix(colorA, colorB, clamp(diff * 0.7 + 0.22, 0.0, 1.0));
            fluidTint += highlight * (vMagnet * 0.9 + fresnel * 0.35);
            fluidTint = mix(fluidTint, vec3(0.0), 0.12);
            gl_FragColor = vec4(fluidTint, 1.0);
          }
        `,
      });

      this.sphere = new THREE.Mesh(geometry, material);
      this.scene.add(this.sphere);

      const rim = new THREE.PointLight(0x61ffd6, 0.7, 15, 2);
      rim.position.set(-3, 3.5, 4.2);
      this.scene.add(rim);
      this.scene.add(new THREE.AmbientLight(0x0a1115, 0.85));
    }

    bindEvents() {
      window.addEventListener("resize", this.resize);
      this.hero.addEventListener("pointermove", this.handlePointerMove);
      this.hero.addEventListener("pointerleave", this.handlePlanetLeave);
      this.hero.querySelectorAll(".planet-link").forEach((planet) => {
        planet.addEventListener("pointerenter", this.handlePlanetActivate);
        planet.addEventListener("pointerdown", this.handlePlanetActivate);
        planet.addEventListener("focus", this.handlePlanetActivate);
        planet.addEventListener("pointerleave", this.handlePlanetLeave);
        planet.addEventListener("blur", this.handlePlanetLeave);
      });
    }

    resize() {
      const size = Math.min(window.innerWidth * 0.39, 430);
      this.canvas.style.width = `${size}px`;
      this.canvas.style.height = `${size}px`;
      this.renderer.setSize(size, size, false);
      this.composer.setSize(size, size);
      this.camera.aspect = 1;
      this.camera.updateProjectionMatrix();
    }

    handlePointerMove(event) {
      const planet = event.target instanceof Element ? event.target.closest(".planet-link") : null;
      if (!planet) return;
      this.activateMagnet(planet, 1.1);
    }

    handlePlanetActivate(event) {
      const planet = event.currentTarget instanceof Element
        ? event.currentTarget
        : event.target instanceof Element
          ? event.target.closest(".planet-link")
          : null;
      if (!planet) return;

      const boost = event.type === "pointerdown" ? 1.45 : 1.25;
      this.activateMagnet(planet, boost);
    }

    activateMagnet(planet, strength) {
      const heroRect = this.hero.getBoundingClientRect();
      const rect = planet.getBoundingClientRect();
      const x = (rect.left + rect.width / 2 - heroRect.left) / heroRect.width;
      const y = (rect.top + rect.height / 2 - heroRect.top) / heroRect.height;
      this.pointer.set(x * 2 - 1, -(y * 2 - 1));
      this.targetStrength = strength;
    }

    handlePlanetLeave() {
      this.targetStrength = 0;
    }

    tick() {
      const t = this.clock.getElapsedTime();
      this.magnetStrength += (this.targetStrength - this.magnetStrength) * 0.08;
      this.targetStrength *= 0.985;

      this.magnet.lerp(this.pointer, 0.16);
      const magnetDir = new THREE.Vector3(this.magnet.x, this.magnet.y, 0.85).normalize();

      this.sphere.material.uniforms.time.value = t;
      this.sphere.material.uniforms.magnetDir.value.copy(magnetDir);
      this.sphere.material.uniforms.magnetStrength.value = this.magnetStrength;
      this.sphere.rotation.y += 0.0035;
      this.sphere.rotation.x = Math.sin(t * 0.28) * 0.11;

      this.composer.render();
      requestAnimationFrame(this.tick);
    }
  }


  class FerroFluidFallback {
    constructor(canvas, hero) {
      this.canvas = canvas;
      this.hero = hero;
      this.ctx = this.canvas.getContext("2d");
      this.dpr = window.devicePixelRatio || 1;
      this.center = { x: 0, y: 0 };
      this.baseRadius = 80;
      this.time = 0;
      this.targetStrength = 0;
      this.strength = 0;
      this.targetPoint = { x: 0, y: 0 };
      this.magnet = null;

      this.resize = this.resize.bind(this);
      this.tick = this.tick.bind(this);
      this.handlePlanetActivate = this.handlePlanetActivate.bind(this);
      this.handlePlanetLeave = this.handlePlanetLeave.bind(this);

      this.resize();
      window.addEventListener("resize", this.resize);
      this.hero.querySelectorAll(".planet-link").forEach((planet) => {
        planet.addEventListener("pointerenter", this.handlePlanetActivate);
        planet.addEventListener("pointerdown", this.handlePlanetActivate);
        planet.addEventListener("focus", this.handlePlanetActivate);
        planet.addEventListener("pointerleave", this.handlePlanetLeave);
        planet.addEventListener("blur", this.handlePlanetLeave);
      });
      requestAnimationFrame(this.tick);
    }

    resize() {
      const size = Math.min(window.innerWidth * 0.39, 430);
      this.baseRadius = size * 0.27;
      this.canvas.width = size * this.dpr;
      this.canvas.height = size * this.dpr;
      this.canvas.style.width = `${size}px`;
      this.canvas.style.height = `${size}px`;
      this.ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
      this.center.x = size / 2;
      this.center.y = size / 2;
    }

    handlePlanetActivate(event) {
      const planet = event.currentTarget instanceof Element
        ? event.currentTarget
        : event.target instanceof Element
          ? event.target.closest(".planet-link")
          : null;
      if (!planet) return;
      const heroRect = this.hero.getBoundingClientRect();
      const rect = planet.getBoundingClientRect();
      this.magnet = {
        x: rect.left + rect.width / 2 - heroRect.left,
        y: rect.top + rect.height / 2 - heroRect.top,
      };
      this.targetStrength = event.type === "pointerdown" ? 1.4 : 1.15;
    }

    handlePlanetLeave() {
      this.targetStrength = 0;
    }

    tick() {
      this.time += 0.015;
      this.strength += (this.targetStrength - this.strength) * 0.08;
      this.targetStrength *= 0.985;

      const rect = this.canvas.getBoundingClientRect();
      const heroRect = this.hero.getBoundingClientRect();
      const cx = rect.left + rect.width / 2 - heroRect.left;
      const cy = rect.top + rect.height / 2 - heroRect.top;
      if (this.magnet) {
        this.targetPoint.x = this.magnet.x - cx;
        this.targetPoint.y = this.magnet.y - cy;
      } else {
        this.targetPoint.x *= 0.92;
        this.targetPoint.y *= 0.92;
      }

      this.draw();
      requestAnimationFrame(this.tick);
    }

    draw() {
      const ctx = this.ctx;
      const w = this.canvas.width / this.dpr;
      const h = this.canvas.height / this.dpr;
      ctx.clearRect(0, 0, w, h);

      const angleToMagnet = Math.atan2(this.targetPoint.y, this.targetPoint.x);
      const dist = Math.hypot(this.targetPoint.x, this.targetPoint.y);
      const pullInfluence = Math.min(1, dist / (w * 0.45)) * this.strength;
      const points = 180;

      ctx.beginPath();
      for (let i = 0; i <= points; i++) {
        const t = (i / points) * Math.PI * 2;
        const wobble = Math.sin(t * 12 + this.time * 3.0) * 6 + Math.sin(t * 18 - this.time * 4.0) * 4;
        const delta = Math.abs(Math.atan2(Math.sin(t - angleToMagnet), Math.cos(t - angleToMagnet)));
        const directionPull = Math.max(0, 1 - delta / 1.0);
        const spike = Math.pow(directionPull, 2.15) * this.baseRadius * 0.95 * pullInfluence;
        const radius = this.baseRadius + wobble + spike;
        const x = this.center.x + Math.cos(t) * radius;
        const y = this.center.y + Math.sin(t) * radius;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();

      const bodyGrad = ctx.createRadialGradient(
        this.center.x - this.baseRadius * 0.44,
        this.center.y - this.baseRadius * 0.5,
        this.baseRadius * 0.15,
        this.center.x,
        this.center.y + this.baseRadius * 0.18,
        this.baseRadius * 1.35,
      );
      bodyGrad.addColorStop(0, "#0c1e20");
      bodyGrad.addColorStop(0.28, "#041113");
      bodyGrad.addColorStop(0.7, "#010808");
      bodyGrad.addColorStop(1, "#000203");
      ctx.fillStyle = bodyGrad;
      ctx.fill();

      const edge = ctx.createLinearGradient(
        this.center.x - this.baseRadius,
        this.center.y - this.baseRadius,
        this.center.x + this.baseRadius,
        this.center.y + this.baseRadius,
      );
      edge.addColorStop(0, "rgba(117, 246, 218, 0.22)");
      edge.addColorStop(0.4, "rgba(117, 246, 218, 0.06)");
      edge.addColorStop(1, "rgba(0, 0, 0, 0.45)");
      ctx.strokeStyle = edge;
      ctx.lineWidth = 1.3;
      ctx.stroke();

      const highlight = ctx.createRadialGradient(
        this.center.x - this.baseRadius * 0.34,
        this.center.y - this.baseRadius * 0.38,
        this.baseRadius * 0.07,
        this.center.x - this.baseRadius * 0.28,
        this.center.y - this.baseRadius * 0.34,
        this.baseRadius * 0.55,
      );
      highlight.addColorStop(0, "rgba(161, 255, 235, 0.28)");
      highlight.addColorStop(0.45, "rgba(109, 248, 222, 0.11)");
      highlight.addColorStop(1, "rgba(109, 248, 222, 0)");
      ctx.globalCompositeOperation = "screen";
      ctx.fillStyle = highlight;
      ctx.fill();
      ctx.globalCompositeOperation = "source-over";
    }
  }

  async function loadThreeDeps() {
    if (THREE && EffectComposer && RenderPass && UnrealBloomPass) return true;

    try {
      const threeModule = await import("https://unpkg.com/three@0.162.0/build/three.module.js");
      const composerModule = await import("https://unpkg.com/three@0.162.0/examples/jsm/postprocessing/EffectComposer.js");
      const renderPassModule = await import("https://unpkg.com/three@0.162.0/examples/jsm/postprocessing/RenderPass.js");
      const bloomModule = await import("https://unpkg.com/three@0.162.0/examples/jsm/postprocessing/UnrealBloomPass.js");
      THREE = threeModule;
      EffectComposer = composerModule.EffectComposer;
      RenderPass = renderPassModule.RenderPass;
      UnrealBloomPass = bloomModule.UnrealBloomPass;
      return true;
    } catch (error) {
      console.error("Ferrofluid dependencies failed to load:", error);
      return false;
    }
  }

  window.addEventListener("DOMContentLoaded", async () => {
    const container = document.querySelector(".a-rays");
    if (container) new Rays(container);

    const ferroCanvas = document.querySelector(".ferro-canvas");
    const hero = document.querySelector(".hero");
    if (!(ferroCanvas instanceof HTMLCanvasElement) || !(hero instanceof HTMLElement)) return;

    const ready = await loadThreeDeps();
    if (ready) new FerroFluid(ferroCanvas, hero);
    else new FerroFluidFallback(ferroCanvas, hero);
  });
</script>

</BaseLayout>
